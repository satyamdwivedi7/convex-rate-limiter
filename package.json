{
  "name": "convex-rate-limiter",
  "version": "0.1.7",
  "description": "Fixed-window rate limiting component for Convex apps",
  "license": "MIT",
  "keywords": [
    "convex",
    "rate-limit",
    "rate-limiting",
    "component"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/satyamdwivedi7/convex-rate-limiter.git"
  },
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./convex.config.js": {
      "import": "./dist/convex.config.js",
      "types": "./dist/convex.config.d.ts"
    },
    "./_generated/component.js": {
      "import": "./_generated/component.js",
      "types": "./_generated/component.d.ts"
    },
    "./test": {
      "import": "./test/index.js",
      "types": "./test/index.d.ts"
    }
  },
  "files": [
    "dist",
    "convex.config.ts",
    "schema.ts",
    "rateLimits.ts",
    "utils.ts",
    "crons.ts",
    "_generated/",
    "test/index.js",
    "test/index.d.ts"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "convex": ">=1.17.0"
  },
  "peerDependenciesMeta": {
    "convex": {
      "optional": false
    }
  },
  "devDependencies": {
    "@edge-runtime/vm": "^3.2.0",
    "convex": "^1.17.0",
    "convex-test": "^0.0.33",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
